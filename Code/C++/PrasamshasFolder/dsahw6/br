#!/bin/bash

# Compile the program
g++ -std=c++11 -Wall main.cpp -o hw7 || { echo "Compile failed"; exit 1; }

echo "===== Test graph ====="
echo "Nodes: 0..4"
echo "Edges (undirected, weight):"
echo "0-1 (2)"
echo "0-2 (4)"
echo "1-2 (1)"
echo "1-3 (7)"
echo "2-4 (3)"
echo "3-4 (1)"
echo

############################################################
# Mode 0: IsEdge(a, b)
# Here: a=0, b=1 => edge exists, expect output: 1
############################################################
echo "===== Mode 0: IsEdge(0,1) ====="
./hw7 <<EOF
0 5 0 1
0 1 2
0 2 4
1 2 1
1 3 7
2 4 3
3 4 1
EOF
echo           # newline

############################################################
# Mode 1: IsPath(a, b)
# Here: a=0, b=4 => path exists, expect output: 1
############################################################
echo "===== Mode 1: IsPath(0,4) ====="
./hw7 <<EOF
1 5 0 4
0 1 2
0 2 4
1 2 1
1 3 7
2 4 3
3 4 1
EOF
echo

############################################################
# Mode 2: Degree(a)
# Here: a=1; neighbors: 0,2,3 => degree = 3
############################################################
echo "===== Mode 2: Degree(1) ====="
./hw7 <<EOF
2 5 1 0
0 1 2
0 2 4
1 2 1
1 3 7
2 4 3
3 4 1
EOF
echo

############################################################
# Mode 3: DFT(a)
# Here: a=0; with your DFS logic, expected traversal: 0 1 2 4 3
# Program prints them concatenated: 01243
############################################################
echo "===== Mode 3: DFT starting at 0 ====="
./hw7 <<EOF
3 5 0 0
0 1 2
0 2 4
1 2 1
1 3 7
2 4 3
3 4 1
EOF
echo    # after traversal line

############################################################
# Mode 4: BFT(a)
# Here: a=0; BFS in node-number order => 0 1 2 3 4
# Program prints: 01234
############################################################
echo "===== Mode 4: BFT starting at 0 ====="
./hw7 <<EOF
4 5 0 0
0 1 2
0 2 4
1 2 1
1 3 7
2 4 3
3 4 1
EOF
echo

############################################################
# Mode 5: Dijkstra(a, b)
# Here: a=0, b=4
# Shortest path: 0 -> 1 -> 2 -> 4
# Edge weights: 0-1=2, 1-2=1, 2-4=3 -> total = 6
# Expected output:
#   length: 4
#   weight: 6
#   path:   0124
############################################################
echo "===== Mode 5: Dijkstra(0,4) ====="
./hw7 <<EOF
5 5 0 4
0 1 2
0 2 4
1 2 1
1 3 7
2 4 3
3 4 1
EOF
echo
