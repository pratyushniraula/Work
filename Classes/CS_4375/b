# ensure we’re on Homebrew python
which python3
python3 -V   # 3.13.x

# install packages to your user site (bypasses PEP 668 for libs)
python3 -m pip install --user numpy seaborn

# (optional) if you later install CLI tools with --user, expose their bin dir:
echo 'export PATH="$HOME/Library/Python/3.13/bin:$PATH"' >> ~/.zshrc
exec zsh -l

# verify import
python3 -c "import numpy; print(numpy.__version__)"